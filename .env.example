# ==============================================================================
# IG-trading — Configurazione (copia in .env e compila)
# Bot quant su CFD IG. Vedi docs/DIARIO-CONVERSIONE-IG.md e docs/ARCHITETTURA-BOT.md
# ==============================================================================


# ==============================================================================
# 1 — IG API
# ==============================================================================
# API key da: My IG > Impostazioni > API keys. La key DEMO e' diversa dalla LIVE.
IG_API_KEY=your_ig_api_key_here
# Username di login (NON l'email).
IG_IDENTIFIER=your_ig_username_here
IG_PASSWORD=your_ig_password_here
IG_ACC_TYPE=DEMO                       # DEMO (demo-api.ig.com) | LIVE (api.ig.com)
IG_ACCOUNT_ID=                         # opzionale; vuoto = conto default del login
IG_EPIC=IX.D.SPTRD.IFE.IP              # US 500 Cash (1€), EUR, €1/punto, min 1.0


# ==============================================================================
# 2 — RISK MANAGEMENT (globale, tutte le strategie)
# ==============================================================================
INITIAL_EQUITY=500                     # equity conto
BASE_RISK_PCT=0.01                     # rischio base per trade (frazione equity)
MAX_DAILY_LOSS_PCT=0.03                # kill switch: stop nuovi ingressi dopo -3%/giorno
MAX_OPEN_TRADES=3                      # max posizioni aperte contemporanee
MAX_GROSS_EXPOSURE=3.0                 # leva lorda aggregata max (2-3x consigliato)
HEALTH_CHECK_INTERVAL_SEC=5            # ping IG ogni N secondi (issue #9)
MAX_API_DOWN_SEC=30                    # allarme LOG se IG down > N sec (NO flat auto)


# ==============================================================================
# 3 — LOGGING E MONITORING
# ==============================================================================
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
MONITORING_INTERVAL_MINUTES=15
TELEGRAM_BOT_TOKEN=                    # alert (vuoto = disabilitato)
TELEGRAM_CHAT_ID=
DASHBOARD_ADMIN_PASSWORD=              # sblocca pagine sensibili della dashboard


# ==============================================================================
# 4 — ABILITAZIONE STRATEGIE  (true = attiva; aggiungerne = 1 modulo + 1 flag)
# ==============================================================================
DIP_BUY_ENABLED=true                   # EDGE #1 validato (docs/EDGE-1-compra-il-dip.md)
# TREND_ENABLED=false                  # Trend Breakdown: netto ~piatto su US500


# ==============================================================================
# 5 — STRATEGIA: DIP BUY (mean-reversion intraday, EDGE #1)
# Regole: long se close>SMA200 AND RSI(2)<entry; scale-in su dip piu' profondi;
# exit su close>SMA(exit) / RSI2>exit_high / max_hold; intraday (flat overnight).
# NIENTE stop stretto (peggiora la MR — testato). Vedi docs/EDGE-1-compra-il-dip.md.
# ==============================================================================
DIP_EPIC=IX.D.SPTRD.IFE.IP             # strumento (US500)
DIP_ENTRY_RSI=10                       # entra se RSI(2) < questo
DIP_EXIT_RSI=70                        # esci se RSI(2) > questo
DIP_EXIT_MA=10                         # esci se close > SMA(questo)
DIP_MAX_HOLD_DAYS=10                   # time exit
DIP_SCALE_IN=2                         # unita' extra su dip piu' profondi (0=off)
DIP_ADD_RSI=5                          # aggiungi una unita' se RSI(2) < questo
DIP_FLAT_BEFORE_CLOSE_MIN=10
DIP_INTRADAY=true                      # flat overnight (leverabile, no gap/financing)
DIP_LEVERAGE=3.0                       # leva target (2-3x); attenzione a size min IG

# ── Conto REALE (opzioni US500) — usato da sampler skew / run_spread / pilot ──
# Login DIVERSO dal demo. Il conto opzioni è separato dal conto CFD.
IG_LIVE_API_KEY=la-tua-api-key-live
IG_LIVE_IDENTIFIER=il-tuo-username-live
IG_LIVE_PASSWORD=la-tua-password-live
IG_LIVE_ACCOUNT_ID=TVYYM

# ── Opzioni: arm per-strategia (modulare, default = nessuno apre) ──
# Gate demone (sampler_daemon): entrambi true per passare --arm a run_spread.
# Allowlist: quali strategie POSSONO aprire se il gate è aperto.
# Esempio solo put: OPTIONS_ARMED_STRATEGIES=putspread
# Call dopo: aggiungi callspread in lista — zero cambio codice demone.
OPTIONS_DAEMON_ARM=false
OPTIONS_DAEMON_I_UNDERSTAND_LIVE_RISK=false
OPTIONS_ARMED_STRATEGIES=


# ==============================================================================
# 6 — GITHUB ISSUES (issuebeam) — bug/task tracking da chat Cursor
# Token: GitHub > Settings > Developer settings > Personal access tokens (repo scope)
# ==============================================================================
GITHUB_REPO=IGEdge/igedge
GITHUB_TOKEN=your_github_pat_here

# ── Sicurezza bot CFD (issue #5): DEFAULT = PLAN-ONLY (nessun ordine) ──
# Per inviare ordini: --arm da CLI, o BOT_ARM=true (container).
# Su conto LIVE serve ANCHE --i-understand-live-risk / BOT_I_UNDERSTAND_LIVE_RISK=true.
BOT_ARM=false
BOT_I_UNDERSTAND_LIVE_RISK=false
